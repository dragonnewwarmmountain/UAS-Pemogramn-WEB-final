// apps/backend/prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // Tidak ada lagi deklarasi 'output' di sini. 
  // Prisma Client akan otomatis di-generate ke node_modules/@prisma/client
}

datasource db {
  provider = "postgresql"
  // Konfigurasi URL mengikuti standar Prisma v7 (menggunakan prisma.config.ts atau env langsung)
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  displayName    String
  createdAt      DateTime     @default(now())
  
  ownedTasks     Task[]       @relation("TaskOwner")
  assignedTasks  Task[]       @relation("TaskAssignee")
  memberships    TaskMember[]
  sentInvites    Invitation[] @relation("InviterRelation")
  comments       Comment[]
  
  // Relasi Delegasi Tingkat Sub-Tugas (Stage)
  assignedStages SubTask[]    @relation("SubTaskAssignee") 
}

model Task {
  id           String       @id @default(uuid())
  title        String
  description  String?      @db.Text
  status       String       @default("todo") 
  difficultySp Int          @default(1)
  dueDate      DateTime?
  isSequential Boolean      @default(false)
  isArchived   Boolean      @default(false) 
  
  // Penanda Mutlak Arsitektur Collaboration Hub
  isCollab     Boolean      @default(false) 
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ownerId      String
  owner        User         @relation("TaskOwner", fields: [ownerId], references: [id])

  assigneeId   String?
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  members      TaskMember[]
  invitations  Invitation[]
  subTasks     SubTask[]
  comments     Comment[]
  attachments  Attachment[]
}

model TaskMember {
  id        String   @id @default(uuid())
  role      String   @default("editor") 
  joinedAt  DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId]) 
}

model Invitation {
  id        String   @id @default(uuid())
  email     String   
  token     String   @unique 
  role      String   @default("editor") 
  status    String   @default("pending") 
  createdAt DateTime @default(now())
  expiresAt DateTime 

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  inviterId String
  inviter   User     @relation("InviterRelation", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

model SubTask {
  id          String   @id @default(uuid())
  title       String
  isCompleted Boolean  @default(false)
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Modul Pemetaan Eksekutor di Tingkat Stage
  assigneeId  String?  
  assignee    User?    @relation("SubTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull) 
}

model Comment {
  id        String   @id @default(uuid())
  text      String   @db.Text
  createdAt DateTime @default(now())
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String   @db.Text
  fileType  String   @default("link")
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}